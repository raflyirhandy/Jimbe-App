<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sage_gradient">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/cardBottomNav"
        app:layout_constraintTop_toTopOf="parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvProfileTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Profil Member JIMBE"
                android:textColor="@color/sage_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileImage"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="50dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:id="@+id/ivProfilePicture"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:padding="20dp"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/sage_text_secondary"
                    android:background="#EAEAEA"
                    android:contentDescription="@null" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/sage_surface"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📧 Email Terdaftar"
                        android:textColor="@color/sage_text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/sage_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔑 User ID Firebase"
                        android:textColor="@color/sage_text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvProfileUID"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/sage_text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 Nomor HP Aktif"
                        android:textColor="@color/sage_text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvProfilePhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/sage_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Alamat Rumah"
                        android:textColor="@color/sage_text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvProfileAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/sage_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogout"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Keluar Dari Akun"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@android:color/holo_red_dark"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@color/sage_nav_dark"
        app:cardCornerRadius="35dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="4">

            <ImageView
                android:id="@+id/ivHomeNav"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:contentDescription="@null"
                android:src="@drawable/ic_home"
                app:tint="@color/sage_text_secondary" />

            <ImageView
                android:id="@+id/ivStatisticNav"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:contentDescription="@null"
                android:src="@drawable/baseline_insert_chart_24"
                app:tint="@color/sage_text_secondary" />

            <ImageView
                android:id="@+id/ivChatNav"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:contentDescription="@null"
                android:src="@drawable/ic_chat"
                app:tint="@color/sage_text_secondary" />

            <ImageView
                android:id="@+id/ivProfileNav"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:contentDescription="@null"
                android:src="@drawable/ic_profile"
                app:tint="@android:color/white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>