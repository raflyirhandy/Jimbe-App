<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_sage_gradient">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FF8A5C"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@android:color/white"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/ivBack"
            android:layout_marginStart="12dp"
            android:text="Kalkulator BMI &amp; Nutrisi"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card Input Data Tubuh -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Input Data Tubuh"
                        android:textColor="@color/sage_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Gender Selection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jenis Kelamin"
                        android:textColor="@color/sage_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardMale"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="12dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#FF8A5C"
                            app:cardBackgroundColor="#FFEBE3">
                            <TextView
                                android:id="@+id/tvMaleText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="👦 Laki-Laki"
                                android:textColor="#FF8A5C"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardFemale"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="12dp"
                            app:strokeWidth="0dp"
                            app:cardBackgroundColor="#F0F4F8">
                            <TextView
                                android:id="@+id/tvFemaleText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="👧 Perempuan"
                                android:textColor="@color/sage_text_secondary" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Height, Weight, Age Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tinggi (cm)"
                                android:textColor="@color/sage_text_secondary"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />
                            <EditText
                                android:id="@+id/etTinggi"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/bg_input_field_light"
                                android:inputType="numberDecimal"
                                android:gravity="center"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="14sp"
                                android:importantForAutofill="no" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Berat (kg)"
                                android:textColor="@color/sage_text_secondary"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />
                            <EditText
                                android:id="@+id/etBerat"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/bg_input_field_light"
                                android:inputType="numberDecimal"
                                android:gravity="center"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="14sp"
                                android:importantForAutofill="no" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Umur (thn)"
                                android:textColor="@color/sage_text_secondary"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />
                            <EditText
                                android:id="@+id/etUmur"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/bg_input_field_light"
                                android:inputType="number"
                                android:gravity="center"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="14sp"
                                android:importantForAutofill="no" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Activity Level -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tingkat Aktivitas Harian"
                        android:textColor="@color/sage_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spAktivitas"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field_light"
                        android:theme="@android:style/Theme.Holo.Light.NoActionBar"
                        android:layout_marginBottom="16dp" />

                    <!-- Calculate Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalculate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Hitung Sekarang"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="#FF8A5C"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Layout Results (Initially Hidden) -->
            <LinearLayout
                android:id="@+id/layoutResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- BMI Result Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="20dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start"
                            android:text="⚖️ Hasil Kategori BMI"
                            android:textColor="@color/sage_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <!-- Large styled score layout -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp"
                            android:background="#F0F4F8"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:id="@+id/tvBmiScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="18.7"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="38sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SKOR BMI"
                                android:textColor="@color/sage_text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBmiCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#10B981"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="6dp"
                            android:text="Ideal (Normal)"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvBmiDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Luar biasa! Berat badan Anda berada di rentang ideal. Pertahankan pola makan seimbang..."
                            android:textColor="@color/sage_text_secondary"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:layout_marginBottom="16dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E2E8F0"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:id="@+id/tvIdealRange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RENTANG BERAT IDEAL: 50.4 kg - 67.8 kg"
                            android:textColor="@color/sage_accent_orange"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- BMR & TDEE Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Basal Metabolic Rate"
                                android:textColor="@color/sage_text_secondary"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tvBmr"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="1446 kcal"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TDEE (Kalori Harian)"
                                android:textColor="@color/sage_text_secondary"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tvTdee"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="1989 kcal"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Nutrition Targets Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="20dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🥗 Target Nutrisi Harian"
                            android:textColor="@color/sage_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <!-- Goal Tab Selection -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:weightSum="3"
                            android:background="@drawable/bg_input_field_light"
                            android:padding="4dp"
                            android:layout_marginBottom="20dp">

                            <TextView
                                android:id="@+id/btnGoalCutting"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="Cutting"
                                android:textColor="@color/sage_text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true"/>

                            <TextView
                                android:id="@+id/btnGoalMaintain"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="Maintain"
                                android:textColor="#FFFFFF"
                                android:background="@drawable/bg_tab_selected"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true"/>

                            <TextView
                                android:id="@+id/btnGoalBulking"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="Bulking"
                                android:textColor="@color/sage_text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>

                        <!-- Target Calorie Text -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="TARGET ASUPAN KALORI HARIAN"
                            android:textColor="@color/sage_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTargetCalories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="4dp"
                            android:text="1989 kcal / hari"
                            android:textColor="@color/sage_accent_orange"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="20dp" />

                        <!-- Macronutrient List Items -->
                        <!-- Carbs -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="#F0F4F8"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍞"
                                android:textSize="18sp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Karbohidrat (Carbs)"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvCarbsText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#3B82F6"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="271g (55%)" />
                        </LinearLayout>

                        <!-- Protein -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="#F0F4F8"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🥩"
                                android:textSize="18sp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Protein"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvProteinText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#10B981"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="102g (21%)" />
                        </LinearLayout>

                        <!-- Fat -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="#F0F4F8">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🥑"
                                android:textSize="18sp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Lemak (Fat)"
                                android:textColor="@color/sage_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvFatText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#F59E0B"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="53g (24%)" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Save Results Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveResults"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Simpan Hasil"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#10B981"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
