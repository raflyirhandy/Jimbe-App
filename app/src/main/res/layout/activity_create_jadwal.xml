<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sage_gradient"
    tools:context=".CreateJadwalActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Buat Kelas Latihan"
                android:textColor="@color/sage_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Latihan"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etNamaLatihan"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        android:hint="Contoh: Yoga Dasar"
                        android:textColorHint="#999999"
                        android:inputType="text"
                        android:textColor="#1E1E1E" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Deskripsi Latihan"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etDeskripsiLatihan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        android:hint="Masukkan deskripsi singkat..."
                        android:textColorHint="#999999"
                        android:inputType="textMultiLine"
                        android:maxLines="3"
                        android:textColor="#1E1E1E" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Tanggal"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etTanggal"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        android:hint="Contoh: 12 Mei 2026"
                        android:textColorHint="#999999"
                        android:inputType="text"
                        android:textColor="#1E1E1E" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Jam"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etJam"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        android:hint="Contoh: 15:00 WIB"
                        android:textColorHint="#999999"
                        android:inputType="text"
                        android:textColor="#1E1E1E" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Kuota Peserta"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etKuota"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        android:hint="Contoh: 20"
                        android:textColorHint="#999999"
                        android:inputType="number"
                        android:textColor="#1E1E1E" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Background Latar Kelas"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                    
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Pilih Gambar dari Galeri"
                        app:icon="@android:drawable/ic_menu_gallery"
                        app:cornerRadius="8dp"
                        app:backgroundTint="#F0F0F0"
                        android:textColor="#1E1E1E"
                        app:iconTint="#1E1E1E"/>
                        
                    <ImageView
                        android:id="@+id/ivPreviewImage"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSimpanKelas"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:text="Simpan Kelas"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/jimbe_primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
