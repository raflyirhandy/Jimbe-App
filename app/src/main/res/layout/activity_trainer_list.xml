<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sage_gradient"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Pilih Trainer Konsultasi"
        android:textColor="@color/sage_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Silakan pilih personal trainer aktif kamu"
        android:textColor="@color/sage_text_secondary"
        android:textSize="14dp"
        android:layout_marginBottom="24dp"/>

    <!-- Trainer 1 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTrainer1"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/sage_surface"
        app:cardCornerRadius="20dp"
        app:strokeWidth="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:padding="16dp">
            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/bg_sage_gradient"
                android:padding="8dp"
                android:src="@drawable/ic_default_avatar"
                app:tint="@android:color/white" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:id="@+id/tvNamaTrainer1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memuat..."
                    android:textColor="@color/sage_text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spesialis Bulking &amp; Powerlifting"
                    android:textColor="@color/sage_text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Trainer 2 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTrainer2"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/sage_surface"
        app:cardCornerRadius="20dp"
        app:strokeWidth="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:padding="16dp">
            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/bg_sage_gradient"
                android:padding="8dp"
                android:src="@drawable/ic_default_avatar"
                app:tint="@android:color/white" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:id="@+id/tvNamaTrainer2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memuat..."
                    android:textColor="@color/sage_text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spesialis Cutting &amp; Cardio"
                    android:textColor="@color/sage_text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>